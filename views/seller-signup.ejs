<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Registration — FreshCart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body>
<%- include('partials/navbar') %>

<div class="fc-form-card" style="max-width:520px; border-top: 4px solid var(--fc-orange)">
  <div class="form-brand-logo">🏪 Seller <span>Portal</span></div>
  <h2 class="text-center mb-1" style="color:var(--fc-orange)">Register Your Shop</h2>
  <p class="text-center text-muted mb-4">Start selling on FreshCart today</p>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form action="/seller/signup" method="POST">
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Your Name</label>
        <input type="text" name="name" class="form-control" placeholder="Full name" required>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Shop Name</label>
        <input type="text" name="shopName" class="form-control" placeholder="My Fresh Store" required>
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Email</label>
      <input type="email" name="email" class="form-control" placeholder="seller@example.com" required>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Phone</label>
      <input type="text" name="phone" class="form-control" placeholder="9876543210" maxlength="10">
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Location / City</label>
      <input type="text" name="location" class="form-control" placeholder="Chennai, Tamil Nadu">
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Password</label>
      <input type="password" name="password" class="form-control" placeholder="Min. 6 characters" required minlength="6">
    </div>
    <div class="mb-4">
      <label class="form-label fw-semibold">Confirm Password</label>
      <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat password" required>
    </div>
    <button type="submit" class="btn btn-fc-accent w-100 py-2 fw-bold">
      Create Seller Account
    </button>
  </form>

  <p class="text-center mt-3 text-muted">
    Already registered? <a href="/seller/login" class="fw-semibold" style="color:var(--fc-orange)">Login</a>
  </p>
  <p class="text-center text-muted small mt-1">
    Want to buy instead? <a href="/login" class="text-success">Buyer Login</a>
  </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>