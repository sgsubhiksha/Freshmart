<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout — FreshCart</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body>
<%- include('partials/navbar') %>

<div class="container py-5">
  <h2 class="mb-4">📦 Checkout</h2>

  <div class="row g-4">
    <!-- Delivery Form -->
    <div class="col-lg-7">
      <div class="fc-summary-card">
        <h5 class="fw-bold mb-4">🏠 Delivery Details</h5>
        <form id="checkout-form">
          <div class="mb-3">
            <label class="form-label fw-semibold">Street Address</label>
            <input type="text" id="street" name="street" class="form-control" placeholder="123 Main Street">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-semibold">City</label>
              <input type="text" id="city" name="city" class="form-control" placeholder="Chennai">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-semibold">PIN Code</label>
              <input type="text" id="pincode" name="pincode" class="form-control" placeholder="600001" maxlength="6">
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label fw-semibold">Phone Number</label>
            <input type="text" id="phone" name="phone" class="form-control" placeholder="9876543210" maxlength="10">
          </div>

          <h5 class="fw-bold mb-3">💳 Payment Method</h5>
          <div class="d-flex gap-3 mb-4">
            <div class="form-check payment-option p-3 border rounded flex-grow-1" style="cursor:pointer">
              <input class="form-check-input" type="radio" name="paymentMethod" id="cod" value="COD" checked>
              <label class="form-check-label fw-semibold w-100" for="cod" style="cursor:pointer">
                💵 Cash on Delivery
              </label>
              <small class="text-muted">Pay when your order arrives</small>
            </div>
            <div class="form-check payment-option p-3 border rounded flex-grow-1" style="cursor:pointer">
              <input class="form-check-input" type="radio" name="paymentMethod" id="online" value="Online">
              <label class="form-check-label fw-semibold w-100" for="online" style="cursor:pointer">
                💳 Online Payment
              </label>
              <small class="text-muted">UPI, Card, Net Banking</small>
            </div>
          </div>

          <button type="submit" id="place-order-btn" class="btn btn-fc-accent w-100 py-2 fw-bold fs-5">
            🎉 Place Order
          </button>
        </form>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="col-lg-5">
      <div class="fc-summary-card">
        <h5 class="fw-bold mb-3">🧾 Order Summary</h5>
        <% cart.forEach(item => { %>
          <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
            <div class="d-flex align-items-center gap-2">
              <img src="<%= item.image %>" width="40" height="40"
                   style="object-fit:cover;border-radius:6px"
                   onerror="this.src='https://images.unsplash.com/photo-1542838132-92c53300491e?w=100&h=100&fit=crop'">
              <div>
                <div class="fw-semibold small"><%= item.name %></div>
                <div class="text-muted small">Qty: <%= item.quantity %></div>
              </div>
            </div>
            <span class="fw-semibold">₹<%= (item.price * item.quantity).toFixed(2) %></span>
          </div>
        <% }) %>

        <div class="d-flex justify-content-between mt-3 mb-1">
          <span>Subtotal</span>
          <span>₹<%= total.toFixed(2) %></span>
        </div>
        <div class="d-flex justify-content-between mb-1 text-muted small">
          <span>Delivery</span>
          <span class="text-success fw-semibold">FREE</span>
        </div>
        <hr>
        <div class="d-flex justify-content-between fw-bold fs-5">
          <span>Total</span>
          <span class="text-success">₹<%= total.toFixed(2) %></span>
        </div>

        <div class="mt-3 p-2 bg-light rounded small text-muted">
          🕐 Estimated delivery: <strong>30–45 minutes</strong>
        </div>
      </div>

      <a href="/cart" class="btn btn-outline-secondary w-100 mt-3">← Back to Cart</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
