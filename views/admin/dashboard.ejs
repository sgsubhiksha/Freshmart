<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body class="bg-light">

  <%- include('../partials/navbar') %>

  <div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fw-bold mb-0">Admin Dashboard</h2>
        <p class="text-muted mb-0">Welcome, <%= user.name %></p>
      </div>
      <span class="badge bg-warning text-dark fs-6">Admin Panel</span>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
      <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-4">
          <div class="fs-1 mb-2">📦</div>
          <h3 class="fw-bold text-primary"><%= stats.totalProducts %></h3>
          <p class="text-muted mb-0">Total Products</p>
          <a href="/admin/products" class="stretched-link"></a>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-4">
          <div class="fs-1 mb-2">🛒</div>
          <h3 class="fw-bold text-success"><%= stats.totalOrders %></h3>
          <p class="text-muted mb-0">Total Orders</p>
          <a href="/admin/orders" class="stretched-link"></a>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-4">
          <div class="fs-1 mb-2">👥</div>
          <h3 class="fw-bold text-info"><%= stats.totalUsers %></h3>
          <p class="text-muted mb-0">Registered Users</p>
        </div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm text-center p-4">
          <div class="fs-1 mb-2">💰</div>
          <h3 class="fw-bold text-warning">₹<%= stats.totalRevenue?.toFixed(2) || '0.00' %></h3>
          <p class="text-muted mb-0">Total Revenue</p>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h5 class="fw-bold mb-3">Quick Actions</h5>
            <div class="d-flex flex-column gap-2">
              <a href="/admin/products" class="btn btn-outline-primary">Manage Products</a>
              <a href="/admin/orders" class="btn btn-outline-success">Manage Orders</a>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <h5 class="fw-bold mb-3">Recent Orders</h5>
            <% if (recentOrders && recentOrders.length > 0) { %>
              <ul class="list-group list-group-flush">
                <% recentOrders.slice(0, 5).forEach(order => { %>
                  <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                    <span class="small">#<%= order._id.toString().slice(-6).toUpperCase() %> — <%= order.user?.name || 'Unknown' %></span>
                    <span class="badge bg-<%= order.status === 'Delivered' ? 'success' : order.status === 'Cancelled' ? 'danger' : 'warning text-dark' %>">
                      <%= order.status %>
                    </span>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="text-muted">No recent orders.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
