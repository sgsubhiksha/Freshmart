<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> — FreshCart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body>
<%- include('partials/navbar') %>

<div class="container py-5">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/products">Shop</a></li>
      <li class="breadcrumb-item"><%= product.category %></li>
      <li class="breadcrumb-item active"><%= product.name %></li>
    </ol>
  </nav>

  <!-- Product Info -->
  <div class="row g-5 mb-5">
    <div class="col-md-6">
      <img src="<%= product.image %>" class="product-detail-img" alt="<%= product.name %>"
           onerror="this.src='https://images.unsplash.com/photo-1542838132-92c53300491e?w=400&h=300&fit=crop'">
    </div>
    <div class="col-md-6">
      <span class="badge-category"><%= product.category %></span>
      <h1 class="mt-2"><%= product.name %></h1>
      <p class="text-muted"><%= product.description %></p>

      <!-- Rating summary -->
      <div class="d-flex align-items-center gap-2 mb-3">
        <% for(let i=1; i<=5; i++) { %>
          <span style="color:<%= i <= Math.round(product.averageRating || 0) ? '#f4a261' : '#ddd' %>;font-size:1.3rem">★</span>
        <% } %>
        <span class="text-muted small">
          (<%= product.reviewCount || 0 %> review<%= product.reviewCount !== 1 ? 's' : '' %>)
        </span>
      </div>

      <div class="fc-price fs-2 my-3">₹<%= product.price.toFixed(2) %>
        <span class="text-muted fs-6 fw-normal">/ <%= product.unit || 'piece' %></span>
      </div>

      <% if (product.stock === 0) { %>
        <div class="alert alert-warning">😔 Currently out of stock.</div>
      <% } else { %>
        <p class="<%= product.stock <= 5 ? 'fc-stock-low' : 'text-muted small' %>">
          <% if (product.stock <= 5) { %>⚠️ Only <%= product.stock %> left!
          <% } else { %><%= product.stock %> in stock<% } %>
        </p>
        <div class="d-flex align-items-center gap-3 mt-3">
          <label class="fw-semibold">Qty:</label>
          <select id="qty-select" class="form-select" style="width:90px">
            <% for(let i=1; i<=Math.min(product.stock,10); i++) { %>
              <option value="<%= i %>"><%= i %></option>
            <% } %>
          </select>
          <button class="btn btn-fc-primary add-to-cart" data-id="<%= product._id %>">
            🛒 Add to Cart
          </button>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="row">
    <div class="col-lg-8">
      <h3 class="mb-4" style="font-family:'Fraunces',serif">⭐ Customer Reviews</h3>

      <!-- Flash messages -->
      <% if (locals.query && query.success === 'reviewed') { %>
        <div class="alert alert-success">✅ Your review has been posted!</div>
      <% } %>
      <% if (locals.query && query.error === 'already_reviewed') { %>
        <div class="alert alert-warning">⚠️ You have already reviewed this product.</div>
      <% } %>

      <!-- Leave a review form -->
      <% if (user && user.role === 'customer') { %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Write a Review</h5>
            <form action="/products/<%= product._id %>/review" method="POST">
              <div class="mb-3">
                <label class="form-label fw-semibold">Rating</label>
                <div class="d-flex gap-2">
                  <% for(let i=1; i<=5; i++) { %>
                    <div class="form-check">
                      <input class="form-check-input" type="radio" name="rating"
                             id="star<%= i %>" value="<%= i %>" <%= i === 5 ? 'checked' : '' %> required>
                      <label class="form-check-label" for="star<%= i %>">
                        <%= i %>★
                      </label>
                    </div>
                  <% } %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label fw-semibold">Your Review</label>
                <textarea name="comment" class="form-control" rows="3"
                          placeholder="Share your experience with this product…" required></textarea>
              </div>
              <button type="submit" class="btn btn-fc-primary">Submit Review</button>
            </form>
          </div>
        </div>
      <% } else if (!user) { %>
        <div class="alert alert-info">
          <a href="/login" class="fw-bold">Login</a> to leave a review.
        </div>
      <% } %>

      <!-- Existing Reviews -->
      <% if (reviews.length === 0) { %>
        <div class="fc-empty">
          <div class="fc-empty-icon">💬</div>
          <p>No reviews yet. Be the first to review!</p>
        </div>
      <% } else { %>
        <% reviews.forEach(review => { %>
          <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <span class="fw-bold"><%= review.userName %></span>
                  <div class="text-muted small">
                    <%= new Date(review.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                  </div>
                </div>
                <div>
                  <% for(let i=1; i<=5; i++) { %>
                    <span style="color:<%= i <= review.rating ? '#f4a261' : '#ddd' %>">★</span>
                  <% } %>
                </div>
              </div>
              <p class="mb-2"><%= review.comment %></p>

              <!-- Seller Reply -->
              <% if (review.sellerReply) { %>
                <div class="p-2 rounded mt-2" style="background:#f0faf5;border-left:3px solid #52b788">
                  <small class="fw-bold text-success">🏪 Seller Reply:</small>
                  <p class="mb-0 small mt-1"><%= review.sellerReply %></p>
                </div>
              <% } %>

              <!-- Seller: reply form (only if no reply yet) -->
              <% if (user && user.role === 'seller' && !review.sellerReply) { %>
                <form action="/products/<%= product._id %>/review/<%= review._id %>/reply" method="POST" class="mt-3">
                  <div class="input-group input-group-sm">
                    <input type="text" name="sellerReply" class="form-control"
                           placeholder="Reply to this review…" required>
                    <button type="submit" class="btn btn-outline-success">Reply</button>
                  </div>
                </form>
              <% } %>

              <!-- Admin: delete review button -->
              <% if (user && user.role === 'admin') { %>
                <form action="/products/<%= product._id %>/review/<%= review._id %>/delete"
                      method="POST" class="mt-2"
                      onsubmit="return confirm('Delete this review?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger">🗑 Delete</button>
                </form>
              <% } %>

            </div>
          </div>
        <% }) %>
      <% } %>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', async () => {
      const productId = btn.dataset.id;
      const qty = parseInt(document.getElementById('qty-select').value);
      try {
        const res = await fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, quantity: qty })
        });
        const data = await res.json();
        if (data.success) {
          btn.textContent = '✅ Added!';
          setTimeout(() => btn.textContent = '🛒 Add to Cart', 2000);
        } else {
          alert(data.message || 'Could not add to cart.');
        }
      } catch (err) {
        console.error(err);
        alert('Something went wrong.');
      }
    });
  });
</script>
</body>
</html>