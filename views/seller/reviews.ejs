<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reviews — FreshCart Seller</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="d-flex">
  <%- include('../partials/seller-sidebar') %>
  <div class="flex-grow-1 admin-content">
    <h2 class="mb-4" style="font-family:'Fraunces',serif">⭐ Customer Reviews</h2>

    <% if (reviews.length === 0) { %>
      <div class="fc-empty">
        <div class="fc-empty-icon">⭐</div>
        <p>No reviews yet. Reviews will appear here once customers rate your products.</p>
      </div>
    <% } else { %>
      <% reviews.forEach(review => { %>
        <div class="card mb-3 border-0 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <span class="fw-bold"><%= review.userName %></span>
                <span class="text-muted small ms-2">
                  on <em><%= review.product ? review.product.name : 'Product' %></em>
                </span>
                <div class="text-muted small">
                  <%= new Date(review.createdAt).toLocaleDateString('en-IN') %>
                </div>
              </div>
              <div>
                <% for(let i=1; i<=5; i++) { %>
                  <span style="color:<%= i <= review.rating ? '#f4a261' : '#ddd' %>;font-size:1.1rem">★</span>
                <% } %>
                <span class="ms-1 small text-muted">(<%= review.rating %>/5)</span>
              </div>
            </div>

            <p class="mb-3"><%= review.comment %></p>

            <% if (review.sellerReply) { %>
              <div class="p-3 rounded" style="background:#f0faf5;border-left:3px solid #52b788">
                <small class="fw-bold text-success">🏪 Your Reply:</small>
                <p class="mb-0 small mt-1"><%= review.sellerReply %></p>
              </div>
            <% } else { %>
              <form action="/seller/reviews/reply" method="POST" class="d-flex gap-2 mt-2">
                <input type="hidden" name="reviewId" value="<%= review._id %>">
                <input type="text" name="reply" class="form-control form-control-sm"
                       placeholder="Write a reply to this review…" required>
                <button class="btn btn-sm btn-fc-primary px-3">Reply</button>
              </form>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>