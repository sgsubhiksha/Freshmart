<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile — FreshCart Seller</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="d-flex">
  <%- include('../partials/seller-sidebar') %>
  <div class="flex-grow-1 admin-content">
    <h2 class="mb-4" style="font-family:'Fraunces',serif">👤 Shop Profile</h2>

    <div class="bg-white p-4 rounded shadow-sm" style="max-width:600px">
      <!-- Shop header -->
      <div class="text-center mb-4 p-3 rounded" style="background:#f8f5ef">
        <div style="font-size:3rem">🏪</div>
        <h4 class="fw-bold mb-0"><%= seller.shopName || 'My Shop' %></h4>
        <p class="text-muted small mb-0"><%= seller.location || 'Location not set' %></p>
      </div>

      <form action="/seller/profile" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Your Name</label>
          <input type="text" name="name" class="form-control"
                 value="<%= seller.name %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Shop Name</label>
          <input type="text" name="shopName" class="form-control"
                 value="<%= seller.shopName || '' %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Phone</label>
          <input type="text" name="phone" class="form-control"
                 value="<%= seller.phone || '' %>" maxlength="10">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Location / City</label>
          <input type="text" name="location" class="form-control"
                 value="<%= seller.location || '' %>" placeholder="Chennai, Tamil Nadu">
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Email</label>
          <input type="email" class="form-control" value="<%= seller.email %>" disabled>
          <small class="text-muted">Email cannot be changed.</small>
        </div>
        <button type="submit" class="btn btn-fc-primary w-100 py-2">
          💾 Save Profile
        </button>
      </form>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>