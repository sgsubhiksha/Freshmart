<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — FreshCart Seller</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
<div class="d-flex">
  <%- include('../partials/seller-sidebar') %>
  <div class="flex-grow-1 admin-content">
    <h2 class="mb-4" style="font-family:'Fraunces',serif">Dashboard</h2>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-value">₹<%= totalRevenue.toFixed(0) %></div>
          <div class="stat-label">Total Revenue</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="stat-card orange">
          <div class="stat-value">₹<%= todayRevenue.toFixed(0) %></div>
          <div class="stat-label">Today's Revenue</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="stat-card yellow">
          <div class="stat-value"><%= totalOrders %></div>
          <div class="stat-label">Total Orders</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="stat-card red">
          <div class="stat-value"><%= lowStock.length %></div>
          <div class="stat-label">Low Stock Items</div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <!-- Sales Chart -->
      <div class="col-lg-8">
        <div class="bg-white p-4 rounded shadow-sm">
          <h5 class="fw-bold mb-3">Sales — Last 7 Days</h5>
          <canvas id="salesChart" height="100"></canvas>
        </div>
      </div>

      <!-- Best Selling -->
      <div class="col-lg-4">
        <div class="bg-white p-4 rounded shadow-sm h-100">
          <h5 class="fw-bold mb-3">Best Sellers</h5>
          <% if (bestSelling.length === 0) { %>
            <p class="text-muted">No sales yet.</p>
          <% } else { %>
            <% bestSelling.forEach((p, i) => { %>
              <div class="d-flex justify-content-between mb-2 pb-2 border-bottom">
                <span><%= i+1 %>. <%= p.name %></span>
                <span class="text-success fw-bold"><%= p.qty %> sold</span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <!-- Low Stock Alerts -->
      <% if (lowStock.length > 0) { %>
      <div class="col-12">
        <div class="alert alert-warning">
          <h6 class="fw-bold mb-2">⚠️ Low Stock Alerts</h6>
          <div class="d-flex flex-wrap gap-2">
            <% lowStock.forEach(p => { %>
              <span class="badge bg-warning text-dark fs-6">
                <%= p.name %> — only <%= p.stock %> left
              </span>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Recent Orders -->
      <div class="col-12">
        <div class="bg-white p-4 rounded shadow-sm">
          <h5 class="fw-bold mb-3">📦 Recent Orders</h5>
          <% if (recentOrders.length === 0) { %>
            <div class="fc-empty">
              <div class="fc-empty-icon">📦</div>
              <p>No orders yet. Add products to start receiving orders!</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table">
                <thead style="background:#f5f0e8">
                  <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Amount</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentOrders.forEach(order => { %>
                    <tr>
                      <td>#<%= order._id.toString().slice(-6).toUpperCase() %></td>
                      <td><%= order.user ? order.user.name : 'N/A' %></td>
                      <td><%= order.items.map(i => i.name).join(', ').substring(0, 30) %>…</td>
                      <td>₹<%= order.items.reduce((s,i) => s + i.price * i.quantity, 0).toFixed(2) %></td>
                      <td>
                        <span class="status-badge status-<%= order.status.replace(/ /g,'') %>">
                          <%= order.status %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const chartLabels = <%- JSON.stringify(chartData.map(d => d.label)) %>;
const chartValues = <%- JSON.stringify(chartData.map(d => d.value)) %>;
const ctx = document.getElementById('salesChart').getContext('2d');
new Chart(ctx, {
  type: 'line',
  data: {
    labels: chartLabels,
    datasets: [{
      label: 'Revenue (₹)',
      data: chartValues,
      borderColor: '#2d6a4f',
      backgroundColor: 'rgba(45,106,79,0.1)',
      tension: 0.4,
      fill: true,
      pointBackgroundColor: '#2d6a4f',
    }]
  },
  options: { responsive: true, plugins: { legend: { display: false } } }
});
</script>
</body>
</html>