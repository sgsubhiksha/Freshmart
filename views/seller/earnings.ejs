<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Earnings — FreshCart Seller</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="d-flex">
  <%- include('../partials/seller-sidebar') %>
  <div class="flex-grow-1 admin-content">
    <h2 class="mb-4" style="font-family:'Fraunces',serif">💰 Earnings</h2>

    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-value">₹<%= totalEarnings.toFixed(2) %></div>
          <div class="stat-label">Total Earnings</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card yellow">
          <div class="stat-value">₹<%= pendingEarnings.toFixed(2) %></div>
          <div class="stat-label">Pending (Unsettled)</div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card orange">
          <div class="stat-value">₹<%= settledEarnings.toFixed(2) %></div>
          <div class="stat-label">Settled (Delivered)</div>
        </div>
      </div>
    </div>

    <div class="bg-white p-4 rounded shadow-sm">
      <h5 class="fw-bold mb-3">📋 Payout History</h5>
      <% if (sellerOrders.length === 0) { %>
        <div class="fc-empty">
          <div class="fc-empty-icon">💰</div>
          <p>No earnings yet.</p>
        </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table">
          <thead style="background:#f5f0e8">
            <tr>
              <th>Order ID</th><th>Date</th><th>Customer</th>
              <th>Items</th><th>Amount</th><th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% sellerOrders.forEach(order => { %>
              <tr>
                <td>#<%= order._id.toString().slice(-6).toUpperCase() %></td>
                <td><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                <td><%= order.user ? order.user.name : 'N/A' %></td>
                <td><%= order.items.map(i => i.name).join(', ').substring(0,30) %>…</td>
                <td class="fw-bold text-success">₹<%= order.earning.toFixed(2) %></td>
                <td>
                  <span class="badge <%= order.status === 'Delivered' ? 'bg-success' : 'bg-warning text-dark' %>">
                    <%= order.status === 'Delivered' ? '✅ Settled' : '⏳ Pending' %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>