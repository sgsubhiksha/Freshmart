<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders — FreshCart Seller</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="d-flex">
  <%- include('../partials/seller-sidebar') %>
  <div class="flex-grow-1 admin-content">
    <h2 class="mb-4" style="font-family:'Fraunces',serif">📦 Incoming Orders</h2>

    <% if (orders.length === 0) { %>
      <div class="fc-empty">
        <div class="fc-empty-icon">📦</div>
        <p>No orders yet. Keep adding great products!</p>
      </div>
    <% } else { %>
      <% orders.forEach(order => { %>
        <div class="card mb-4 border-0 shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center py-3"
               style="background:#f8f5ef">
            <div>
              <span class="fw-bold">
                Order #<%= order._id.toString().slice(-8).toUpperCase() %>
              </span>
              <span class="text-muted small ms-3">
                <%= new Date(order.createdAt).toLocaleDateString('en-IN') %>
              </span>
            </div>
            <span class="fw-bold text-success">
              ₹<%= order.items.reduce((s,i) => s + i.price * i.quantity, 0).toFixed(2) %>
            </span>
          </div>
          <div class="card-body">
            <div class="mb-3 small text-muted">
              <strong>👤</strong> <%= order.user ? order.user.name : 'N/A' %>
              (<%= order.user ? order.user.email : '' %>) &nbsp;|&nbsp;
              <strong>📍</strong> <%= order.address.street %>, <%= order.address.city %>
              — <%= order.address.pincode %> &nbsp;|&nbsp;
              <strong>📞</strong> <%= order.address.phone %>
            </div>
            <% order.items.forEach(item => { %>
              <div class="d-flex justify-content-between align-items-center p-2 mb-2 rounded"
                   style="background:#f9f7f3">
                <div>
                  <span class="fw-semibold"><%= item.name %></span>
                  <span class="text-muted ms-2">× <%= item.quantity %></span>
                  <span class="ms-2 text-success fw-bold">
                    ₹<%= (item.price * item.quantity).toFixed(2) %>
                  </span>
                </div>
                <select class="form-select form-select-sm" style="width:160px"
                        onchange="updateStatus('<%= order._id %>', '<%= item.product %>', this.value)">
                  <% ['Pending','Processing','Packed','Shipped','Delivered'].forEach(s => { %>
                    <option value="<%= s %>" <%= item.sellerStatus === s ? 'selected' : '' %>>
                      <%= s %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<div id="fc-toast" style="position:fixed;bottom:2rem;right:2rem;z-index:9999"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
function updateStatus(orderId, productId, status) {
  $.post('/seller/orders/status', { orderId, productId, status }, function(res) {
    if (res.success) {
      const toast = $('<div class="fc-toast-item success">✅ Status updated to ' + status + '!</div>');
      $('#fc-toast').append(toast);
      setTimeout(() => toast.fadeOut(400, () => toast.remove()), 2500);
    }
  });
}
</script>
</body>
</html>