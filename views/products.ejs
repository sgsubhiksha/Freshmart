<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FreshCart</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body>
<%- include('partials/navbar') %>

<div class="fc-hero">
  <div class="container">
    <h1>Fresh from the Market</h1>
    <p class="lead mb-3">Groceries, snacks, beverages & more — delivered to your door.</p>
    <div class="fc-search-wrap d-flex">
      <input type="text" id="search-input" placeholder="Search for mangoes, chips, milk…" class="form-control flex-grow-1">
      <button type="button">Search</button>
    </div>
  </div>
</div>

<div class="container mb-3 mt-3">
  <div class="d-flex flex-wrap gap-2">
    <button class="fc-category-pill active" data-category="All">🍽️ All</button>
    <% categories.forEach(cat => { %>
      <button class="fc-category-pill" data-category="<%= cat %>"><%= cat %></button>
    <% }) %>
  </div>
</div>

<div class="container mb-5">
  <div class="row" id="products-grid">
    <div class="text-center py-5 col-12">
      <div class="spinner-border text-success"></div>
    </div>
  </div>
</div>

<!-- Floating Cart Button -->
<a href="/cart" id="floating-cart" style="display:none">
  🛒 <span id="floating-count">0</span>
</a>

<%- include('partials/footer') %>
</body>
</html>