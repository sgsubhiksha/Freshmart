<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join FreshCart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
  <style>
    body { background: var(--fc-cream); }
    .page-wrap { min-height: 100vh; display: flex; align-items: center; }
    .role-card {
      border: 2px solid #e8e0d0;
      border-radius: 20px;
      padding: 2.5rem 2rem;
      cursor: pointer;
      transition: all 0.3s ease;
      background: #fff;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .role-card:hover { transform: translateY(-8px); color: inherit; text-decoration: none; }
    .role-card.buyer:hover {
      box-shadow: 0 0 0 3px #52b788, 0 20px 40px rgba(45,106,79,0.2);
      background: linear-gradient(135deg, #f0faf5, #ffffff);
      border-color: transparent;
    }
    .role-card.seller:hover {
      box-shadow: 0 0 0 3px #e76f51, 0 20px 40px rgba(231,111,81,0.2);
      background: linear-gradient(135deg, #fff5f0, #ffffff);
      border-color: transparent;
    }
    .role-icon { font-size: 4rem; margin-bottom: 1rem; }
    .role-title { font-family: 'Fraunces', serif; font-size: 1.8rem; font-weight: 700; }
    .role-desc { color: #6c757d; margin-top: 0.5rem; }
    .role-features { list-style: none; padding: 0; margin-top: 1rem; text-align: left; }
    .role-features li { padding: 4px 0; font-size: 0.9rem; color: #555; }
    .role-features li::before { content: '✓ '; color: #52b788; font-weight: 700; }
    .role-card.seller .role-features li::before { color: #e76f51; }
    .brand { font-family: 'Fraunces', serif; font-size: 2.2rem; color: var(--fc-green); }
    .brand span { color: var(--fc-orange); }
  </style>
</head>
<body>
<div class="page-wrap">
  <div class="container py-5">

    <div class="text-center mb-5">
      <div class="brand">Fresh<span>Cart</span> 🥬</div>
      <h2 class="mt-2" style="font-family:'Fraunces',serif">
        <%= mode === 'signup' ? 'Create your account' : 'Welcome back!' %>
      </h2>
      <p class="text-muted">
        <%= mode === 'signup' ? 'Choose how you want to join FreshCart' : 'Choose how you want to login' %>
      </p>
    </div>

    <div class="row justify-content-center g-4">

      <!-- Buyer Card -->
      <div class="col-md-5">
        <a href="<%= mode === 'signup' ? '/signup' : '/login' %>" class="role-card buyer text-center">
          <div class="role-icon">🛒</div>
          <div class="role-title" style="color:#2d6a4f">I'm a Buyer</div>
          <p class="role-desc">Browse fresh products and get them delivered to your door.</p>
          <ul class="role-features">
            <li>Browse 100s of fresh products</li>
            <li>Easy cart & checkout</li>
            <li>Track your orders</li>
            <li>Rate & review products</li>
          </ul>
          <div class="mt-3">
            <span class="btn btn-fc-primary px-4">
              <%= mode === 'signup' ? 'Sign Up as Buyer →' : 'Login as Buyer →' %>
            </span>
          </div>
        </a>
      </div>

      <!-- Seller Card -->
      <div class="col-md-5">
        <a href="<%= mode === 'signup' ? '/seller/signup' : '/seller/login' %>" class="role-card seller text-center">
          <div class="role-icon">🏪</div>
          <div class="role-title" style="color:#e76f51">I'm a Seller</div>
          <p class="role-desc">List your products and reach thousands of hungry customers.</p>
          <ul class="role-features">
            <li>List & manage products</li>
            <li>Track incoming orders</li>
            <li>Earnings & analytics</li>
            <li>Customer reviews</li>
          </ul>
          <div class="mt-3">
            <span class="btn btn-fc-accent px-4">
              <%= mode === 'signup' ? 'Sign Up as Seller →' : 'Login as Seller →' %>
            </span>
          </div>
        </a>
      </div>

    </div>

    <p class="text-center text-muted mt-4 small">
      <% if (mode === 'signup') { %>
        Already have an account?
        <a href="/join?mode=login" class="text-success fw-semibold">Buyer Login</a> ·
        <a href="/join?mode=login" class="text-danger fw-semibold">Seller Login</a>
      <% } else { %>
        Don't have an account?
        <a href="/join?mode=signup" class="text-success fw-semibold">Buyer Signup</a> ·
        <a href="/join?mode=signup" class="text-danger fw-semibold">Seller Signup</a>
      <% } %>
    </p>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
