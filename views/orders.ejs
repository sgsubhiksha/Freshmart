<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FreshCart – My Orders</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body class="bg-light">

  <%- include('partials/navbar') %>

  <div class="container py-5">
    <h2 class="fw-bold mb-4">📦 My Orders</h2>

    <% if (locals.success) { %>
      <div class="alert alert-success alert-dismissible fade show">
        <%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (locals.error) { %>
      <div class="alert alert-danger alert-dismissible fade show">
        <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (!orders || orders.length === 0) { %>
      <div class="text-center py-5">
        <div class="fs-1 mb-3">📭</div>
        <h4 class="text-muted">You haven't placed any orders yet.</h4>
        <a href="/products" class="btn btn-primary mt-3">Start Shopping</a>
      </div>
    <% } else { %>
      <div class="d-flex flex-column gap-4">
        <% orders.forEach(order => { %>
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
              <div>
                <span class="fw-bold">Order #<%= order._id.toString().slice(-8).toUpperCase() %></span>
                <span class="text-muted ms-3 small">
                  <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
                </span>
              </div>
              <span class="badge fs-6
                <% if (order.status === 'Delivered') { %>bg-success
                <% } else if (order.status === 'Cancelled') { %>bg-danger
                <% } else if (order.status === 'Shipped') { %>bg-info text-dark
                <% } else { %>bg-warning text-dark<% } %>">
                <%= order.status %>
              </span>
            </div>

            <div class="card-body p-0">
              <table class="table mb-0 align-middle">
                <thead class="table-light">
                  <tr>
                    <th class="ps-4">Product</th>
                    <th class="text-center">Qty</th>
                    <th class="text-end">Price</th>
                    <% if (order.status === 'Delivered') { %>
                      <th class="text-center pe-4">Review</th>
                    <% } else { %>
                      <th class="pe-4"></th>
                    <% } %>
                  </tr>
                </thead>
                <tbody>
                  <% order.items.forEach(item => { %>
                    <tr>
                      <td class="ps-4"><%= item.product?.name || item.name || 'Product removed' %></td>
                      <td class="text-center"><%= item.quantity %></td>
                      <td class="text-end">₹<%= item.price.toFixed(2) %></td>
                      <td class="text-center pe-4">
                        <% if (order.status === 'Delivered' && item.product) { %>
                          <% if (reviewedProductIds.has(item.product._id.toString())) { %>
                            <span class="badge bg-success-subtle text-success">✅ Reviewed</span>
                          <% } else { %>
                            <button class="btn btn-sm btn-outline-warning"
                              data-bs-toggle="modal"
                              data-bs-target="#reviewModal"
                              data-product-id="<%= item.product._id %>"
                              data-product-name="<%= item.product.name || item.name %>">
                              ⭐ Review
                            </button>
                          <% } %>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
                <tfoot class="table-light">
                  <tr>
                    <td colspan="3" class="ps-4 fw-bold">Total</td>
                    <td class="text-end pe-4 fw-bold text-primary">₹<%= order.total.toFixed(2) %></td>
                  </tr>
                </tfoot>
              </table>
            </div>

            <div class="card-footer bg-white text-muted small py-2 px-4">
              Payment: <strong><%= order.paymentMethod %></strong> &nbsp;|&nbsp;
              Address: <%= order.shippingAddress %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Review Modal -->
  <div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow">
        <form action="/orders/review" method="POST">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold" id="reviewModalLabel">⭐ Leave a Review</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body pt-2">
            <input type="hidden" name="productId" id="reviewProductId">
            <p class="text-muted small mb-3">Reviewing: <strong id="reviewProductName"></strong></p>

            <!-- Star rating -->
            <div class="mb-3">
              <label class="form-label fw-semibold">Rating</label>
              <div class="d-flex gap-2 fs-4" id="starContainer">
                <% for (let i = 1; i <= 5; i++) { %>
                  <span class="star-btn" data-value="<%= i %>" style="cursor:pointer;color:#ddd;">★</span>
                <% } %>
              </div>
              <input type="hidden" name="rating" id="ratingInput" required>
            </div>

            <!-- Comment -->
            <div class="mb-3">
              <label for="reviewComment" class="form-label fw-semibold">Comment</label>
              <textarea class="form-control" id="reviewComment" name="comment" rows="3"
                placeholder="Share your experience with this product…" required></textarea>
            </div>
          </div>
          <div class="modal-footer border-0 pt-0">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-warning fw-semibold px-4" id="submitReviewBtn" disabled>
              Submit Review
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
    // Pass product id + name into the modal when opened
    const reviewModal = document.getElementById('reviewModal');
    reviewModal.addEventListener('show.bs.modal', e => {
      const btn = e.relatedTarget;
      document.getElementById('reviewProductId').value = btn.dataset.productId;
      document.getElementById('reviewProductName').textContent = btn.dataset.productName;
      // Reset state
      document.getElementById('ratingInput').value = '';
      document.getElementById('reviewComment').value = '';
      document.getElementById('submitReviewBtn').disabled = true;
      document.querySelectorAll('.star-btn').forEach(s => s.style.color = '#ddd');
    });

    // Interactive star rating
    const stars = document.querySelectorAll('.star-btn');
    const ratingInput = document.getElementById('ratingInput');
    const submitBtn = document.getElementById('submitReviewBtn');

    stars.forEach(star => {
      star.addEventListener('click', () => {
        const val = parseInt(star.dataset.value);
        ratingInput.value = val;
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.value) <= val ? '#f4a261' : '#ddd';
        });
        submitBtn.disabled = false;
      });

      star.addEventListener('mouseover', () => {
        const val = parseInt(star.dataset.value);
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.value) <= val ? '#f4a261' : '#ddd';
        });
      });

      star.addEventListener('mouseout', () => {
        const current = parseInt(ratingInput.value) || 0;
        stars.forEach(s => {
          s.style.color = parseInt(s.dataset.value) <= current ? '#f4a261' : '#ddd';
        });
      });
    });
  </script>
</body>
</html>