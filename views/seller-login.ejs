<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Login — FreshCart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥬</text></svg>">
</head>
<body>
<%- include('partials/navbar') %>

<div class="fc-form-card" style="border-top: 4px solid var(--fc-orange)">
  
  <h2 class="text-center mb-1" style="color:var(--fc-orange)">Seller Login</h2>
  <p class="text-center text-muted mb-4">Sign in to your seller account</p>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form action="/seller/login" method="POST">
    <div class="mb-3">
      <label class="form-label fw-semibold">Email</label>
      <input type="email" name="email" class="form-control" placeholder="seller@example.com" required>
    </div>
    <div class="mb-4">
      <label class="form-label fw-semibold">Password</label>
      <input type="password" name="password" class="form-control" placeholder="••••••••" required>
    </div>
    <button type="submit" class="btn btn-fc-accent w-100 py-2 fw-bold">
      Login as Seller
    </button>
  </form>

  <p class="text-center mt-3 text-muted">
    New seller? <a href="/seller/signup" class="fw-semibold" style="color:var(--fc-orange)">Register your shop</a>
  </p>
  <p class="text-center text-muted small mt-2">
    Looking to buy? <a href="/login" class="text-success">Buyer Login</a>
  </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>